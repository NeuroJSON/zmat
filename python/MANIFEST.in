# Python binding source and metadata
include pyzmat.c
include README.md
include setup.py
include pyproject.toml

# C source tree (copied from ../src and ../include by setup.py)
graft csrc

# Exclude build artifacts
global-exclude *.o *.a *.so *.dylib *.dll *.mex* *.oct *.S *.s
global-exclude __pycache__ *.pyc